# Server
NODE_ENV=development
PORT=5000

# API
API_PREFIX=/api

# CORS (comma-separated origins, or * for all in dev only)
CORS_ORIGIN=http://localhost:5173,http://localhost:5000

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# --- Microsoft SQL Server (matches ODBC "SQL Server" driver — not MS Access) ---
# Leave all DB_* empty to run the API without a database connection.
DB_SERVER=
DB_PORT=1433
DB_DATABASE=
DB_USER=
# Wrap in double quotes if the value contains # (comment) or spaces, e.g. DB_PASSWORD="secret#123"
DB_PASSWORD=

# TLS to server (legacy hosts often need TRUST_SERVER_CERTIFICATE=true)
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true

DB_CONNECTION_TIMEOUT_MS=15000
DB_REQUEST_TIMEOUT_MS=15000
DB_POOL_MAX=10

# Read-only ping for /health. Keep false if you must not execute any SQL.
DB_HEALTHCHECK_SELECT_ONE=false

# --- MySQL (phoenix_users.users) — register / login ---
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=phoenix_users

# Required when MySQL is configured (min 16 chars). Used to sign JWT access tokens.
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=30d
BCRYPT_ROUNDS=10
